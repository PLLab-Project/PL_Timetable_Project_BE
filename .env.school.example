# 학교 서버용 복사본입니다: cp .env.school.example .env
# 실제 비밀번호·도메인·메일 계정으로 바꾼 뒤 scripts/bootstrap-school.sh를 실행합니다.

POSTGRES_DB=pl_timetable
POSTGRES_USER=pl_timetable
POSTGRES_PASSWORD=CHANGE_ME_USE_A_LONG_RANDOM_PASSWORD
POSTGRES_PORT=15432

# API는 기본적으로 호스트 루프백에만 공개합니다.
# 호스트의 Cloudflare Tunnel이 Docker bridge를 통해 접근하면 172.17.0.1 등을 사용합니다.
API_BIND_ADDRESS=127.0.0.1
API_PORT=18082
APP_IMAGE_TAG=school
APP_VERSION=0.0.1-SNAPSHOT
SERVER_FORWARD_HEADERS_STRATEGY=framework

SPRING_PROFILES_ACTIVE=prod
ALLOWED_ORIGINS=https://frontend.example.ac.kr,http://localhost:5173
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax
OPENAPI_ENABLED=true

SCHOOL_EMAIL_DOMAIN=daejin.ac.kr
OTP_EXPIRATION_SECONDS=300
OTP_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_DELIVERY=smtp
OTP_FROM=no-reply@example.ac.kr

SMTP_HOST=smtp.example.ac.kr
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true
